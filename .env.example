# Browser-visible configuration. Leave blank when frontend and API share an origin.
VITE_API_BASE_URL=

# Backend server
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
PROVIDER_TIMEOUT_MS=15000

# Backend-only Amadeus configuration
AMADEUS_API_BASE_URL=https://test.api.amadeus.com
AMADEUS_TOKEN_URL=https://test.api.amadeus.com/v1/security/oauth2/token
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# Backend-only Gemini configuration
GEMINI_API_KEY=your_restricted_server_key
GEMINI_MODEL=gemini-3.5-flash

# Optional backend-only image enrichment; configure both or neither
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
