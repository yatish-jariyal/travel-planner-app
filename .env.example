# Required for Amadeus airport and flight searches
VITE_AMADEUS_API_BASE_URL=https://test.api.amadeus.com
VITE_TOKEN_URL=https://test.api.amadeus.com/v1/security/oauth2/token
VITE_CLIENT_ID=your_amadeus_client_id
VITE_CLIENT_SECRET=your_amadeus_client_secret

# Required for hotel and attraction suggestions
VITE_GEMINI_API_KEY=your_gemini_api_key

# Optional: both values are required to enrich attraction images
VITE_GOOGLE_SEARCH_API_KEY=
VITE_GOOGLE_SEARCH_ENGINE_ID=
