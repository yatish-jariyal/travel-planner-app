# Browser-visible configuration. Leave blank when frontend and API share an origin.
VITE_API_BASE_URL=

# Backend server
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
PROVIDER_TIMEOUT_MS=15000

# Backend-only flight search configuration
SERPAPI_API_BASE_URL=https://serpapi.com/search.json
SERPAPI_API_KEY=your_serpapi_key
FLIGHT_SEARCH_CURRENCY=INR
FLIGHT_SEARCH_COUNTRY=in
FLIGHT_SEARCH_LANGUAGE=en
FLIGHT_SEARCH_CACHE_TTL_MS=900000

# Backend-only Gemini configuration
GEMINI_API_KEY=your_restricted_server_key
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TIMEOUT_MS=60000

# Optional backend-only image enrichment; configure both or neither
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
